# 示例 secrets 文件
# 用于本地 act 调试 GitHub Actions
# 
# 使用方法:
# 1. 复制此文件为 .secrets (注意: .secrets 已在 .gitignore 中)
# 2. 填入你的实际值
# 3. 运行: act workflow_dispatch --secret-file .secrets

# Maven Central 凭证
MAVEN_CENTRAL_USERNAME=your-maven-central-username
MAVEN_CENTRAL_PASSWORD=your-maven-central-token

# GPG 签名
# 注意: GPG_PRIVATE_KEY 需要是 base64 编码的完整私钥
# 生成方法: 
#   gpg --armor --export-secret-keys YOUR_KEY_ID > private-key.asc
#   在 PowerShell 中:
#     $content = Get-Content private-key.asc -Raw
#     $bytes = [System.Text.Encoding]::UTF8.GetBytes($content)
#     [Convert]::ToBase64String($bytes)
GPG_PRIVATE_KEY=your-base64-encoded-gpg-private-key
GPG_PASSPHRASE=your-gpg-key-passphrase

# GitHub Token (act 需要，使用假的即可)
GITHUB_TOKEN=ghp_fake_token_for_local_testing
